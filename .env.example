# Which app to run (crdc | sts). Default baseURL and smoke use this. See config/apps.ts.
# PROJECT=crdc

# Which environment for that app: prod | qa | stage (and qa2 for crdc only).
# Set only TEST_ENV to use that env's default URL. Optional: set BASE_URL to override.
# If both are set, BASE_URL wins.
TEST_ENV=prod
# BASE_URL=

# Optional: credentials — use env or secrets manager; never commit real values
# TEST_USER_EMAIL=
# TEST_USER_PASSWORD=
